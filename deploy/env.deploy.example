# Copy this file to a private place, for example:
#   ../RoundTable-Ops/env/adv_msk02.env
# and run:
#   DEPLOY_ENV_FILE=../RoundTable-Ops/env/adv_msk02.env ./deploy.sh
#
# Do not commit real hostnames, private paths, operator usernames, or public
# rollout choices to the public RoundTable repo unless they are intended examples.

DEPLOY_HOST=example_user@example.com
DEPLOY_PATH=/srv/RoundTable
DEPLOY_BRANCH=main
DEPLOY_SERVICE=roundtable
DEPLOY_HEALTH_URL=http://127.0.0.1:8380/login
DEPLOY_PYTHON=python3

# auto chooses git pull when DEPLOY_PATH has .git, otherwise rsyncs this local tree.
DEPLOY_MODE=auto

# Set true only when the server .env is production-safe:
# BASE_URL=https://...
# ALLOW_DEV_LOGIN=false
# SESSION_COOKIE_SECURE=true
DEPLOY_PUBLIC=false
