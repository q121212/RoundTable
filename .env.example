# Core
APP_NAME=RoundTable
BASE_URL=http://localhost:8000
DATABASE_PATH=./data/roundtable.db
# Local dev convenience login. DANGER: lets anyone sign in as any user (and become
# admin when ADMIN_GITHUB_LOGINS is empty). MUST be false on any internet-facing deploy.
ALLOW_DEV_LOGIN=false
# Startup refuses ALLOW_DEV_LOGIN=true together with an https BASE_URL. Only set this
# to true for a genuinely private https preview where you accept the auth bypass.
# ALLOW_INSECURE_DEV_LOGIN=false
# Send session cookie only over HTTPS. Auto-on when BASE_URL is https; set explicitly
# if TLS is terminated at a proxy. Leave unset for local http.
# SESSION_COOKIE_SECURE=true
# Set to true ONLY when running behind a reverse proxy you control (e.g. nginx).
# It makes rate limiting read the real client IP from the last X-Forwarded-For
# hop. Leave false for direct exposure so clients cannot spoof their identity.
# TRUST_PROXY_HEADERS=true
ADMIN_GITHUB_LOGINS=your-github-login

# GitHub OAuth / GitHub App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# Optional SMTP notifications. Telegram is the default phone-friendly channel;
# leave these empty if you do not want email delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=roundtable@localhost
SMTP_TLS=true

# Retention (days) for the operational audit table (api_audit). Rows older than
# this are pruned hourly by the in-process maintenance pass.
AUDIT_RETENTION_DAYS=90
# Retention (days) for action_log, which backs the ticket activity history shown
# in the UI. Defaults to ~10 years so history is effectively kept while still
# being bounded. Lower it only if you intentionally want shorter history.
ACTION_LOG_RETENTION_DAYS=3650

# Telegram notifications
TELEGRAM_BOT_TOKEN=
# Optional but required for public deploys when Telegram is enabled. Use the same
# value as Telegram's setWebhook secret_token.
TELEGRAM_WEBHOOK_SECRET=
